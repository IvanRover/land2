rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    match /urls/{id} {
      allow read: if true; // Public can resolve links
      allow create: if true; // Public can create links
      // Not strictly implementing hardened rules phase 4 since this is a public anonymous database where any user can shorten URLs without auth.
    }
  }
}
